# NSW Fuel API credentials (https://api.nsw.gov.au)
# Sign up at https://api.nsw.gov.au and subscribe to the Fuel API
NSW_FUEL_API_KEY=your_api_key_here
NSW_FUEL_API_SECRET=your_api_secret_here

# Victoria Fair Fuel Open Data API (Servo Saver)
# Apply at https://service.vic.gov.au/find-services/transport-and-driving/servo-saver/help-centre/servo-saver-public-api
VIC_FUEL_API_KEY=your_consumer_id_here

# Vercel KV details (Required for 30-day National Trend Graph history)
# Provided automatically if you link a KV database in the Vercel dashboard.
KV_REST_API_URL="your_rest_api_url"
KV_REST_API_TOKEN="your_rest_api_token"
CRON_SECRET="optional_secret_for_cron_auth"
